# Default local database. The app creates data/feedflow.db automatically.
DATABASE_URL=sqlite:///data/feedflow.db
SEED_SAMPLE_DATA=true
CREATE_TABLES_ON_STARTUP=true
RUN_STARTUP_JOBS=true
READ_CACHE_TTL_SECONDS=300
READ_CACHE_PERSIST=true
DB_CONNECT_TIMEOUT_SECONDS=5
DB_POOL_PRE_PING=false
DB_RETRY_ATTEMPTS=8
DB_RETRY_INITIAL_DELAY_SECONDS=2
DB_RETRY_MAX_DELAY_SECONDS=20

# Azure SQL / SQL Server examples:
# Use a SQLAlchemy URL:
# DATABASE_URL=mssql+pyodbc://user:password@server.database.windows.net/database?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=no
#
# Or use a raw ODBC connection string:
# DATABASE_URL=Driver={ODBC Driver 18 for SQL Server};Server=tcp:server.database.windows.net,1433;Database=database;Uid=user;Pwd=password;Encrypt=yes;TrustServerCertificate=no;Connection Timeout=30;
#
# For Azure SQL, usually keep demo seeding off:
# SEED_SAMPLE_DATA=false
# CREATE_TABLES_ON_STARTUP=false
# RUN_STARTUP_JOBS=false
# READ_CACHE_TTL_SECONDS=600
# READ_CACHE_PERSIST=true
# DB_CONNECT_TIMEOUT_SECONDS=5
# DB_POOL_PRE_PING=false
# DB_RETRY_ATTEMPTS=8
# DB_RETRY_INITIAL_DELAY_SECONDS=2
# DB_RETRY_MAX_DELAY_SECONDS=20
