# Default local database. The Next app creates data/feedflow.db with npm run prisma:push.
# Optional. If omitted, the app uses an absolute path to data/feedflow.db.
# SQLITE_DATABASE_URL="file:C:/Users/Admin/Documents/feedFlow/data/feedflow.db"
SEED_SAMPLE_DATA=true
RUN_STARTUP_JOBS=true
APP_BASIC_AUTH_REQUIRED=true
APP_BASIC_AUTH_USERNAME=admin
APP_BASIC_AUTH_PASSWORD=replace-with-a-private-password

# Render durable SQLite example:
# SQLITE_DATABASE_URL="file:/opt/render/project/src/storage/feedflow.db"
# SEED_SAMPLE_DATA=false
# RUN_STARTUP_JOBS=false
# APP_BASIC_AUTH_PASSWORD should be set as a Render secret.
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY should be generated and kept stable in Render.

# The Streamlit/Python version used DATABASE_URL with SQLAlchemy URLs.
# Prisma uses SQLITE_DATABASE_URL with file: URLs for SQLite.
